# === Required ===
# From @BotFather after /newbot
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
# From https://console.anthropic.com/ (Settings -> API Keys)
ANTHROPIC_API_KEY=sk-ant-your-key

# === Optional ===
# Claude model used for parsing + reviews. Opus 4.8 is the default and most capable.
# For lower cost you can set this to claude-haiku-4-5 or claude-sonnet-5.
ANTHROPIC_MODEL=claude-opus-4-8

# Where the flat 90-day tracker files live. Defaults to ./data next to the bot.
# Point this at your real project folder to log straight into it.
DATA_DIR=./data

# Lock the bot to a single Telegram chat (your own). Message the bot, then run
# the bot once and check the console — it logs the chat id of every sender.
# Leave blank to accept anyone (fine for a private, unshared bot).
ALLOWED_CHAT_ID=

# Auto-commit + push the data folder after every write, so nothing is lost if the
# host restarts. Requires the bot to run inside a git repo with push access
# configured (e.g. a token in the remote URL). Set to "true" to enable.
GIT_AUTOCOMMIT=false

# Optional daily "did you log today?" nudge. Set to a 24h local time HH:MM to
# enable (e.g. 20:00). Leave blank for on-demand only. Respects the TZ env var.
DAILY_REMINDER_TIME=

# Timezone for dates and the daily reminder (IANA name). Defaults to the host TZ.
TZ=America/Toronto
